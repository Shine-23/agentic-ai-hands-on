# Copy this file to backend/.env and fill in the values.
# Never commit backend/.env to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic Claude API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# PostgreSQL connection string
# Local example:  postgresql://postgres:password@localhost:5432/devproject_ai
# Railway example: postgresql://user:pass@host:port/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/devproject_ai

# ── Optional ──────────────────────────────────────────────────────────────────

# Comma-separated CORS origins allowed to call the API.
# Defaults to * (all origins) if not set — restrict this in production.
# ALLOW_ORIGINS=http://localhost:3000,https://yourdomain.com
